{
  "name": "sarcasmstack",
  "version": "0.1.0",
  "private": true,
  "description": "SarcasmStack — print-on-demand storefront for sarcastic/humor designs. Next.js + Printify + Cloudflare.",
  "scripts": {
    "prepare": "node scripts/setup-public.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "pages:build": "npx @cloudflare/next-on-pages",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^16.12.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.8",
    "@opennextjs/cloudflare": "^1.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.4",
    "wrangler": "^3.78.0"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
