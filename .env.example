# ── Printify (POD backend) ──────────────────────────────────────────────
# Generate at https://printify.com/app/account/api (Connections → Personal access tokens)
# Leave unset to run the storefront in MOCK mode with sample data.
PRINTIFY_API_KEY=
PRINTIFY_SHOP_ID=28152719
# Comma-separated blueprint ids to surface (defaults to curated set if unset)
PRINTIFY_BLUEPRINT_IDS=
# "true" forces mock mode even if PRINTIFY_API_KEY is present (local dev)
PRINTIFY_FORCE_MOCK=false

# ── Stripe (payments) ───────────────────────────────────────────────────
# Redirect Checkout: the backend creates a Checkout Session with the
# RESTRICTED key (rk_test_... in test mode / rk_live_... at launch) and the
# browser redirects to Stripe's hosted payment page. The publishable key is
# reserved (not read by redirect Checkout) but set for Dashboard tooling.
#
# Vault (test mode):
#   vault kv get -field=restricted-key  secret/sarcasmstack/stripe-test-mode-api-keys
#   vault kv get -field=publishable-key secret/sarcasmstack/stripe-test-mode-api-keys
# GitHub Actions secrets: STRIPE_SECRET_KEY, STRIPE_PUBLISHABLE_KEY.
#
# Restricted key needs: Write→Checkout Sessions, Read→Checkout Sessions,
# Read→Events (webhook signature verification). See security.md in the skill.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret from Stripe CLI (stripe listen) or Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=

# ── App ─────────────────────────────────────────────────────────────────
# Origin used for Stripe success/cancel URLs. In production set to https://sarcasmstack.io
APP_ORIGIN=http://localhost:3000
