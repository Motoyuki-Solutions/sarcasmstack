{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sarcasmstack",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/dist/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "PRINTIFY_FORCE_MOCK": "true"
  }
}
